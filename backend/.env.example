PORT=8000

# Gmail SMTP: create an App Password after enabling 2-Step Verification.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-project-email@gmail.com
SMTP_PASS=your-16-character-gmail-app-password
MAIL_FROM="Project Camp <your-project-email@gmail.com>"

# Keep SMTP failures shorter than the frontend API timeout.
SMTP_CONNECTION_TIMEOUT_MS=8000
SMTP_GREETING_TIMEOUT_MS=8000
SMTP_SOCKET_TIMEOUT_MS=10000

# Put your public backend URL here after deployment. Do not use localhost for
# verification links that other people need to open.
BACKEND_PUBLIC_URL=http://localhost:8000
